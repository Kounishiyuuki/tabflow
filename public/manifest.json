{
  "manifest_version": 3,
  "name": "TabFlow",
  "description": "A simple starting point for organizing browser tabs.",
  "version": "0.1.0",
  "action": {
    "default_popup": "popup.html",
    "default_title": "TabFlow"
  },
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": ["tabs", "tabGroups", "storage"]
}
